            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // [ ]Rust v0.1
            bindings = <&macro_release &kp LCTRL>, <&macro_tap &kp BSPC &kp LS(R) &kp U &kp S &kp T &kp SPACE &kp V &kp N0 &kp DOT &kp N1>;
        };
    };
};
