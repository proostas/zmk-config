            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // ('), "
            bindings = <&macro_tap &kp COMMA &kp SPACE &kp DQT>;
        };
        amrs_m2: amrs_m2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // ('),⏎"
            bindings = <&macro_release &kp LCTRL>, <&macro_tap &kp COMMA &kp RET &kp DQT>;
        };
        // '}'
        amrs_m3: amrs_m3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (})⏎}
            bindings = <&macro_tap &kp RET &kp RBRC>;
        };
        amrs_else_if: amrs_else_if {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (}) else if 
            bindings = <&macro_tap &kp SPACE &kp E &kp L &kp S &kp E &kp SPACE &kp I &kp F &kp SPACE>;
        };
        amrs_else1: amrs_else1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (}) else {
            bindings = <&macro_tap &kp SPACE &kp E &kp L &kp S &kp E &kp SPACE &kp LBRC>;
        };
        // '('
        amrs_self1: amrs_self1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (()&self
            bindings = <&macro_tap &kp AMPS &kp S &kp E &kp L &kp F>;
        };
        amrs_mut_self: amrs_mut_self {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (()&mut self
            bindings = <&macro_release &kp LCTRL>, <&macro_tap &kp AMPS &kp M &kp U &kp T &kp SPACE &kp S &kp E &kp L &kp F>;
        };
        // ')'
        amrs_m4: amrs_m4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // ()) {⏎
            bindings = <&macro_tap &kp SPACE &kp LBRC &kp RET>;
        };
        amrs_m5: amrs_m5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // ())⏎}
            bindings = <&macro_tap &kp RET &kp RBRC>;
        };
        // '*'
        amrs_mut: amrs_mut {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (*)mut 
            bindings = <&macro_tap &kp M &kp U &kp T &kp SPACE>;
        };
        amrs_const1: amrs_const1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (*)const 
            bindings = <&macro_tap &kp C &kp O &kp N &kp S &kp T &kp SPACE>;
        };
        // ':'
        amrs_new: amrs_new {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (:):new(
            bindings = <&macro_tap &kp COLON &kp N &kp E &kp W &kp LPAR>;
        };
        // '&'
        amrs_mut1: amrs_mut1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (&)mut 
            bindings = <&macro_tap &kp M &kp U &kp T &kp SPACE>;
        };
        // ';'
        amrs_m6: amrs_m6 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (;)⏎}
            bindings = <&macro_tap &kp RET &kp RBRC>;
        };
        // '='
        amrs_m7: amrs_m7 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // (=) [
            bindings = <&macro_tap &kp SPACE &kp LBKT>;
        };
        // ' '
        amrs_m8: amrs_m8 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // ( ){⏎
            bindings = <&macro_tap &kp LBRC &kp RET>;
        };
        amrs_mut2: amrs_mut2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // ( )mut 
            bindings = <&macro_tap &kp M &kp U &kp T &kp SPACE>;
        };
        amrs_rust_v03: amrs_rust_v03 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <U_ANTMORPH_MACRO_WAIT>;
            tap-ms = <U_ANTMORPH_MACRO_TAP>;
            // [ ]Rust v0.3
            bindings = <&macro_release &kp LCTRL>, <&macro_tap &kp BSPC &kp LS(R) &kp U &kp S &kp T &kp SPACE &kp V &kp N0 &kp DOT &kp N3>;
        };
    };
};
